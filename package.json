{
  "name": "basic",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "$npm_execpath run build && vite preview",
    "deploy": "$npm_execpath run build && wrangler deploy",
    "check": "biome check src",
    "cf-typegen": "wrangler types --env-interface CloudflareBindings",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "migrate:generate": "drizzle-kit generate:sqlite",
    "migrate:apply": "wrangler d1 migrations apply DB --local --persist-to .wrangler/state/v3"
  },
  "private": true,
  "dependencies": {
    "@hono/zod-validator": "^0.2.1",
    "drizzle-orm": "^0.30.9",
    "hono": "^4.2.5",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@biomejs/biome": "1.7.0",
    "@cloudflare/vite-plugin": "^1.2.3",
    "@cloudflare/workers-types": "^4.20260401.1",
    "@paralleldrive/cuid2": "2.2.2",
    "drizzle-kit": "^0.20.17",
    "nanoid": "5.0.7",
    "typescript": "5.4.5",
    "vite": "^6.3.5",
    "vitest": "^4.1.3",
    "wrangler": "^4.17.0"
  }
}
